APP_ENV=production

# Database
DATABASE_URL=postgresql+psycopg://dms_user:CHANGE_ME@127.0.0.1:5432/dms

# Auth
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS (comma-separated list)
CORS_ALLOW_ORIGINS=https://dms.company.local
CORS_ALLOW_CREDENTIALS=true

# OCR provider settings
# OCR_PROVIDER=trocr_hf
# TROCR_MODEL_PATH=microsoft/trocr-base-handwritten
# OCR_MIN_CONFIDENCE=0.60

# Optional object storage settings (disabled until storage wiring is uncommented)
OBJECT_STORAGE_ENABLED=false
# OBJECT_STORAGE_BACKEND=minio
# OBJECT_STORAGE_BUCKET=dms
#
# MinIO
# MINIO_ENDPOINT=127.0.0.1:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_SECURE=false
#
# S3
# AWS_REGION=us-west-2
# S3_ENDPOINT_URL=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# Optional Label Studio settings
# LABEL_STUDIO_ENABLED=false
# LABEL_STUDIO_URL=http://127.0.0.1:8800
# Personal Access Token (PAT) preferred. Legacy token still supported.
# LABEL_STUDIO_API_KEY=
# Backward-compatible fallback variable:
# LABEL_STUDIO_API_TOKEN=
# Optional override: pat | legacy (auto-detected by default)
# LABEL_STUDIO_AUTH_MODE=pat
# LABEL_STUDIO_PROJECT_ID=1
