# VCS
.git
.gitignore

# Python cache and local env
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.venv/
venv/

# Editor/OS noise
.vscode/
.idea/
.DS_Store

# Local runtime state and secrets
.env
.env.*
!.env.example
.coverage

# Docker/local service data
postgres_data/

# Generated outputs, artifacts, and backups
output/
backups/
*.log
*.tmp
*.bak

# Large sample/source docs not needed in image
*.pdf
*.png
*.jpg
*.jpeg
*.tif
*.tiff

# Node artifacts (if present)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
